{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "packageRules": [
    {
      "matchPackageNames": [
        "*"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "schedule": [
        "* * 1 * *"
      ],
      "groupName": "all stable non-major dependencies",
      "groupSlug": "all-stable-minor-patch",
      "minimumReleaseAge": "1 day",
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "matchPackageNames": [
        "prisma",
        "@prisma/client"
      ],
      "matchUpdateTypes": [
        "major"
      ],
      "groupName": "Prisma",
      "minimumReleaseAge": "1 day"
    },
    {
      "matchPackageNames": [
        "react",
        "react-dom"
      ],
      "matchUpdateTypes": [
        "major"
      ],
      "groupName": "React",
      "minimumReleaseAge": "1 day"
    },
    {
      "matchPackageNames": [
        "next",
        "eslint-config-next"
      ],
      "matchUpdateTypes": [
        "major"
      ],
      "groupName": "Next.js",
      "minimumReleaseAge": "1 day"
    }
  ],
  "branchPrefix": "renovate-",
  "dependencyDashboard": true,
  "ignorePaths": [],
  "internalChecksFilter": "strict",
  "lockFileMaintenance": {
    "enabled": true
  },
  "osvVulnerabilityAlerts": true,
  "prCreation": "immediate",
  "rangeStrategy": "pin",
  "separateMultipleMajor": true,
  "minimumReleaseAge": "1 day",
  "timezone": "Europe/Zurich",
  "vulnerabilityAlerts": {
    "automerge": true,
    "schedule": ["* 0-3 * * *"],
    "minimumReleaseAge": "0 days"
  }
}
